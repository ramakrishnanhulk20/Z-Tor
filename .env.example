# --- packages/contracts (Hardhat vars: npx hardhat vars setup) ---
# MNEMONIC=your twelve word test wallet mnemonic
# INFURA_API_KEY=your_infura_key
# ETHERSCAN_API_KEY=optional_for_verify

# --- apps/web (copy to apps/web/.env.local) ---
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Phase 3 Sepolia — see docs/DEPLOYMENTS.md
NEXT_PUBLIC_ZTOR_REGISTRY=0x21E4D83C5C4329Cad8f59bc7408C49d24A3D39d2
NEXT_PUBLIC_DEPLOY_BLOCK=11114155
NEXT_PUBLIC_ZTOR_FACTORY=0x24c4E6dBe47AE08a87C4B7A53a29107CffD96E95

# Optional: gasless withdraw via relayer (direct withdraw works without this)
NEXT_PUBLIC_RELAYER_URL=http://localhost:8787

